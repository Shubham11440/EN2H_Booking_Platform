# Application
PORT=3000

# PostgreSQL — update with your local credentials
DATABASE_URL="postgresql://postgres:password@localhost:5432/en2h_booking_db?schema=public"

# JWT — use long, random strings (min 32 chars) in production
JWT_SECRET="change-this-to-a-random-secret-min-32-chars"
JWT_EXPIRES_IN="15m"

# Refresh Token
JWT_REFRESH_SECRET="change-this-to-a-different-random-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"
